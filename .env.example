# =============================================================================
# OSINT Investigative Agent — Environment Configuration
# =============================================================================
# Copy this file to a new file named ".env" in the project root, then fill in
# your real values. NEVER commit your actual ".env" file to version control.
#
#   cp .env.example .env
#
# =============================================================================

# --- Google Gemini API -----------------------------------------------------
# Required. Get your FREE API key from https://aistudio.google.com/apikey
# Google AI Studio's free tier includes generous daily rate limits.
GEMINI_API_KEY=your-gemini-api-key-here

# The Gemini model used for planning, extraction, verification, and answer
# synthesis. "gemini-2.0-flash" is fast, cheap/free, and has a large free
# quota — good default for this agent. You can swap in a different Gemini
# model name if you prefer.
GEMINI_MODEL=gemini-2.0-flash

# --- Search Configuration -------------------------------------------------
MAX_SEARCH_RESULTS_PER_SUBQUESTION=5
MAX_SUBQUESTIONS=5

# --- Scraping Configuration ------------------------------------------------
REQUEST_TIMEOUT_SECONDS=10
MAX_PAGE_CHARS=8000
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# --- Application Behavior ---------------------------------------------------
LOG_LEVEL=INFO
